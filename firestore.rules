rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read projects
    match /projects/{projectId} {
      allow read: if true;
      // Only allow write if the user is authenticated
      allow write: if request.auth != null;
    }
    
    // Portfolio collection for dynamic content
    match /portfolio/{documentId} {
      // Allow anyone to read portfolio data
      allow read: if true;
      // Only allow write if the user is authenticated
      allow write: if request.auth != null;
    }

    // Experience collection
    match /experience/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contact messages - anyone can create, only admin can read/delete
    match /contact_messages/{documentId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /analytics/{document=**} {
      allow read: if request.auth != null;
      allow write: if true;
    }
  }
}
